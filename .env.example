# PC Peak Platform — Environment Variables
# Copy this to .env and fill in your keys

# REQUIRED: Get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OPTIONAL: Get from 2captcha.com for fully automated CAPTCHA solving (~$3/1000)
TWO_CAPTCHA_KEY=your-2captcha-key-here

# OPTIONAL: Email notifications when cases update
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password
# NOTIFY_EMAIL=stephen@pcpeak.com
